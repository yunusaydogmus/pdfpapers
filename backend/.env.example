# ════════════════════════════════════════════
# PDFPAPERS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env
# ════════════════════════════════════════════

# ── Serveur ──────────────────────────────────
NODE_ENV=development
PORT=3001

# ── URLs ─────────────────────────────────────
# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5500
# En production : https://pdfpapers.vercel.app

# ── JWT ──────────────────────────────────────
# Générer avec : node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64_CHARS_MINIMUM
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_CHARS_MINIMUM

# Durées de vie
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Base de données ───────────────────────────
DB_PATH=./data/pdfpapers.db

# ── Emails (Nodemailer) ───────────────────────
# Option 1 : SMTP (Gmail, Mailgun, SendGrid…)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_application

# Email qui reçoit les messages du formulaire contact
CONTACT_RECEIVER=contact@pdfpapers.fr

# ── Fichiers uploadés ─────────────────────────
UPLOAD_TMP_DIR=./tmp
# Durée de conservation des fichiers (ms) : 2h = 7200000
FILE_TTL_MS=7200000
# Taille max upload (bytes) : 50 MB
MAX_FILE_SIZE=52428800

# ── Rate limiting ─────────────────────────────
# Fenêtre (ms) : 15 min = 900000
RATE_WINDOW_MS=900000
# Auth : max tentatives par fenêtre
RATE_AUTH_MAX=10
# PDF tools : max requêtes par fenêtre
RATE_PDF_MAX=30
# Contact : max messages par fenêtre
RATE_CONTACT_MAX=5

# ── Bcrypt ────────────────────────────────────
BCRYPT_ROUNDS=12
