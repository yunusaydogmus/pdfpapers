# ════════════════════════════════════════════
# PDFPAPERS — Variables d'environnement
#
# EN LOCAL  : copier en .env et remplir
# SUR RAILWAY : aller dans ton projet →
#               Variables → ajouter chaque ligne
#
# NE JAMAIS commiter le fichier .env
# ════════════════════════════════════════════

# ── Serveur ──────────────────────────────────
# Railway injecte PORT automatiquement, ne pas le changer
NODE_ENV=production

# ── URLs ─────────────────────────────────────
# URL du frontend Vercel (pour CORS) — OBLIGATOIRE
FRONTEND_URL=https://pdfpapers.vercel.app

# ── JWT — OBLIGATOIRE ─────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Lancer 2 fois pour avoir 2 secrets différents
JWT_ACCESS_SECRET=REMPLACER_PAR_64_CARACTERES_ALEATOIRES
JWT_REFRESH_SECRET=REMPLACER_PAR_64_CARACTERES_ALEATOIRES_DIFFERENTS

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Base de données SQLite ───────────────────
# Sur Railway avec volume monté sur /data :
DB_PATH=/data/pdfpapers.db
UPLOAD_TMP_DIR=/data/tmp

# ── Fichiers uploadés ─────────────────────────
FILE_TTL_MS=7200000
MAX_FILE_SIZE=52428800

# ── Rate limiting ─────────────────────────────
RATE_WINDOW_MS=900000
RATE_AUTH_MAX=10
RATE_PDF_MAX=30
RATE_CONTACT_MAX=5

# ── Bcrypt ────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Email — OPTIONNEL (formulaire de contact) ─
# Gmail : activer "Mots de passe d'application" dans ton compte Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ton@email.com
SMTP_PASS=ton_mot_de_passe_application_google
CONTACT_RECEIVER=contact@pdfpapers.fr
